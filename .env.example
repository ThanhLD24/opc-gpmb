# ─── Docker Environment Variables ────────────────────────────
# Copy this file to .env and update with your production values

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=opc
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=opc_gpmb
POSTGRES_PORT=35432          # non-default (avoids conflict with local postgres)

# ─── Backend (FastAPI) ────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
BACKEND_PORT=38081           # non-default (avoids conflict with common dev servers)
UPLOAD_DIR=/app/uploads

# ─── Frontend (Next.js) ───────────────────────────────────────
FRONTEND_PORT=38080          # non-default (avoids conflict with common dev servers)
NEXT_PUBLIC_API_URL=http://localhost:38081

# ─── API URL (for cross-service communication) ───────────────
# Change to your actual server IP/domain when deploying on-premise
API_URL=http://localhost:38081

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
